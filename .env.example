# For local development, put your real database URL in .env.local.
# For Vercel/serverless deployments with Supabase, use the Supavisor
# transaction-mode connection string (typically port 6543).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
TREGO_PUBLIC_APP_URL=https://tregos.store
CRON_SECRET=change-this-reminder-secret
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=verified-sender@example.com
BREVO_SENDER_NAME=TREGO
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key
TREGO_WHATSAPP_NOTIFICATIONS_ENABLED=false
WHATSAPP_CLOUD_ACCESS_TOKEN=your_meta_whatsapp_cloud_api_token
WHATSAPP_PHONE_NUMBER_ID=your_meta_whatsapp_phone_number_id
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-this-whatsapp-webhook-token
WHATSAPP_APP_SECRET=your_meta_app_secret_optional
WHATSAPP_DEFAULT_COUNTRY_CODE=383
TREGO_BOOTSTRAP_ADMIN_NAME=Admin TREGO
TREGO_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
TREGO_BOOTSTRAP_ADMIN_PASSWORD=change-this-password
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id
VITE_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id
VITE_VAPI_PUBLIC_KEY=pk_your_vapi_public_key
VITE_VAPI_ASSISTANT_ID=your_vapi_assistant_id
VITE_VAPI_ASSISTANT_LABEL=Asistenti zanor TREGO
