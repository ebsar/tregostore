{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/static/index.html"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.py?_route=api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/api/index.py?_route=uploads/:path*"
    },
    {
      "source": "/about",
      "destination": "/static/about.html"
    },
    {
      "source": "/kerko",
      "destination": "/static/search.html"
    },
    {
      "source": "/profili-biznesit",
      "destination": "/static/business-profile-public.html"
    },
    {
      "source": "/login",
      "destination": "/static/login.html"
    },
    {
      "source": "/forgot-password",
      "destination": "/static/forgot-password.html"
    },
    {
      "source": "/signup",
      "destination": "/static/signup.html"
    },
    {
      "source": "/verifiko-email",
      "destination": "/static/verify-email.html"
    },
    {
      "source": "/biznesi-juaj",
      "destination": "/static/business-dashboard.html"
    },
    {
      "source": "/llogaria",
      "destination": "/static/account.html"
    },
    {
      "source": "/te-dhenat-personale",
      "destination": "/static/personal-data.html"
    },
    {
      "source": "/adresat",
      "destination": "/static/addresses.html"
    },
    {
      "source": "/porosite",
      "destination": "/static/orders.html"
    },
    {
      "source": "/porosite-e-biznesit",
      "destination": "/static/business-orders.html"
    },
    {
      "source": "/ndrysho-fjalekalimin",
      "destination": "/static/change-password.html"
    },
    {
      "source": "/produkti",
      "destination": "/static/product-detail.html"
    },
    {
      "source": "/wishlist",
      "destination": "/static/wishlist.html"
    },
    {
      "source": "/cart",
      "destination": "/static/cart.html"
    },
    {
      "source": "/adresa-e-porosise",
      "destination": "/static/checkout-address.html"
    },
    {
      "source": "/menyra-e-pageses",
      "destination": "/static/payment-options.html"
    },
    {
      "source": "/kafshet-shtepiake",
      "destination": "/static/pets.html"
    },
    {
      "source": "/admin-products",
      "destination": "/static/admin-products.html"
    },
    {
      "source": "/bizneset-e-regjistruara",
      "destination": "/static/registered-businesses.html"
    },
    {
      "source": "/:path*",
      "destination": "/static/:path*"
    }
  ]
}
