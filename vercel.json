{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.py": {
      "includeFiles": "catalog_import.py"
    }
  },
  "crons": [
    {
      "path": "/api/chat/unread-reminders",
      "schedule": "0 10 * * *"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(trego-logo.png|trego-logo.webp|favicon.png|apple-touch-icon.png|bujqesia.jpg|gjelbert.jpeg|gruri.webp|signup-background-shopping.webp|signup-background-mobile.webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py?_route=api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/api/index.py?_route=uploads/:path*"
    },
    {
      "source": "/about",
      "destination": "/index.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
