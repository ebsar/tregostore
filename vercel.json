      "destination": "/forgot-password.html"
    },
    {
      "source": "/signup",
      "destination": "/signup.html"
    },
    {
      "source": "/verifiko-email",
      "destination": "/verify-email.html"
    },
    {
      "source": "/biznesi-juaj",
      "destination": "/business-dashboard.html"
    },
    {
      "source": "/llogaria",
      "destination": "/account.html"
    },
    {
      "source": "/te-dhenat-personale",
      "destination": "/personal-data.html"
    },
    {
